# Telegram bot runtime configuration example.
# Copy to `bot.env` and replace placeholder values with real ones.

# Log level: debug, info, warn, error.
LOG_LEVEL=info

# File for bot logs.
LOG_FILE_NAME=Bot.log

# Path to persisted per-user bot state.
FILE_STORAGE_PATH=./keep_chat.json

# Path to persisted dialog history for generative mode.
FILE_DIALOG_HISTORY_PATH=./dialog_ai.json

# Telegram bot token from BotFather.
TOKEN_BOT=1234567890:replace-with-your-telegram-bot-token

# Yandex Translate API endpoint.
TRANSLATE_API_ENDPOINT=https://translate.api.cloud.yandex.net/translate/v2/translate

# Yandex language detection endpoint.
DICTIONARY_DETECT_API_ENDPOINT=https://translate.api.cloud.yandex.net/translate/v2/detect

# Yandex Smart Home API endpoint.
SMART_HOME_ENDPOINT=https://api.iot.yandex.net

# Authorization header value for Yandex Translate.
# Example format: `Api-Key <your-key>`.
TRANSLATE_API_KEY=Api-Key replace-with-your-yandex-translate-key

# Generative provider name supported by the project.
# Allowed values depend on the current implementation, e.g. `gemini`, `deepseek`, `openrouter`.
GENERATIVE_NAME=openrouter

# API key for the selected generative provider.
GENERATIVE_API_KEY=replace-with-your-generative-api-key

# Concrete model name for the selected provider.
GENERATIVE_MODEL=google/gemini-2.5-flash-preview

# HTTPS endpoint of the local OAuth/token server used by the bot.
SERVER_ENDPOINT=https://example.com:9443

# OAuth application client id.
CLIENT_ID=replace-with-your-oauth-client-id

# Telegram user id allowed to use owner-only features.
OWNER_ID=123456789

# External page with movie recommendations shown by the bot.
MOVIES_URL=http://example.com:8444/

# mTLS client certificate path used for requests to the local server.
CLIENT_CERT_FILE=/pkg/tls_config/cert/client/client.crt

# mTLS client private key path used for requests to the local server.
CLIENT_KEY_FILE=/pkg/tls_config/cert/client/client.key

# CA certificate path used to trust the local server certificate.
CLIENT_CA_FILE=/pkg/tls_config/cert/server/ca.crt

# Shared API key used by the bot when calling the local OAuth/token server.
API_KEY=replace-with-shared-server-api-key
