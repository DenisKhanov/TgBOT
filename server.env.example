# OAuth/token server runtime configuration example.
# Copy to `server.env` and replace placeholder values with real ones.

# Log level: debug, info, warn, error.
LOG_LEVEL=info

# File for server logs.
LOG_FILE_NAME=Server.log

# Yandex OAuth token exchange endpoint.
OAUTH_ENDPOINT=https://oauth.yandex.ru/token

# Address for the local HTTPS server.
HTTPS_SERVER=0.0.0.0:9443

# TLS server certificate path.
SERVER_CERT_FILE=/pkg/tls_config/cert/server/server.crt

# TLS server private key path.
SERVER_KEY_FILE=/pkg/tls_config/cert/server/server.key

# CA certificate path for validating client certificates.
SERVER_CA_FILE=/pkg/tls_config/cert/server/ca.crt

# OAuth application client id.
CLIENT_ID=replace-with-your-oauth-client-id

# OAuth application client secret.
CLIENT_SECRET=replace-with-your-oauth-client-secret

# Shared API key required from the bot when it asks the server for a token.
API_KEY=replace-with-shared-server-api-key
